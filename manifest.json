{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "content_scripts": [
    {
      "matches": ["*://discord.com/*"],
      "js": [
        "src/content/constants.js",
        "src/content/image-blocker.js",
        "src/content/main.js"
      ]
    }
